{
  "name": "desktoppet-ai",
  "version": "0.1.0",
  "description": "Windows AI 桌面宠物 - Electron 透明悬浮窗口",
  "author": "DesktopPet AI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/desktoppet-ai/desktoppet-ai"
  },
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:main\"",
    "dev:renderer": "vite",
    "dev:main": "wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .",
    "build": "vite build && node scripts/fix-build-paths.js",
    "build:win": "npm run build && electron-builder --win",
    "preview": "vite preview",
    "generate-resources": "node scripts/generate-default-spritesheet.js",
    "postinstall": "npm run generate-resources"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "express": "^4.19.2",
    "cors": "^2.8.5",
    "multer": "^1.4.5-lts.1",
    "adm-zip": "^0.5.12",
    "sharp": "^0.33.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/multer": "^1.4.11",
    "@types/adm-zip": "^0.5.5",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^30.1.0",
    "electron-builder": "^24.13.3",
    "typescript": "^5.4.5",
    "vite": "^5.3.1",
    "vite-plugin-electron": "^0.28.7",
    "vite-plugin-electron-renderer": "^0.14.5",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.desktoppet.ai",
    "productName": "DesktopPet AI",
    "publish": null,
    "directories": {
      "output": "release-build",
      "app": "."
    },
    "files": [
      "dist/main/**/*",
      "dist/renderer/**/*",
      "resources/**/*",
      "package.json",
      "node_modules/**/*",
      "!node_modules/.cache/**",
      "!node_modules/.bin/**"
    ],
    "asarUnpack": [
      "**/node_modules/sharp/**",
      "**/node_modules/@img/**"
    ],
    "win": {
      "target": "dir",
      "icon": "resources/icon.png"
    }
  }
}
